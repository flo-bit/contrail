{
  "lexicon": 1,
  "id": "tools.atmo.space.listMembers",
  "defs": {
    "main": {
      "type": "query",
      "description": "List members of a space. Caller must be a member or the owner.",
      "parameters": {
        "type": "params",
        "required": ["spaceUri"],
        "properties": {
          "spaceUri": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["members"],
          "properties": {
            "members": {
              "type": "array",
              "items": { "type": "ref", "ref": "tools.atmo.space.defs#memberView" }
            }
          }
        }
      },
      "errors": [
        { "name": "NotFound" },
        { "name": "Forbidden" }
      ]
    }
  }
}
